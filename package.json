{
  "name": "redline-mark",
  "displayName": "Redline Mark",
  "description": "VS Code Extension for Interactive Review of Claude-Generated Documents",
  "version": "0.2.0",
  "publisher": "voxnotes",
  "icon": "media/redlinemark.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "redline-mark.openReview",
        "title": "Open in Redline Mark Mode",
        "category": "Redline Mark"
      },
      {
        "command": "redline-mark.sendToClaude",
        "title": "Send Comments to Claude",
        "category": "Redline Mark"
      },
      {
        "command": "redline-mark.resolveComment",
        "title": "Resolve Comment",
        "category": "Redline Mark"
      },
      {
        "command": "redline-mark.addReply",
        "title": "Reply to Comment",
        "category": "Redline Mark"
      },
      {
        "command": "redline-mark.createComment",
        "title": "Add Comment",
        "category": "Redline Mark",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "redline-mark.closeReview",
        "title": "Close Review",
        "category": "Redline Mark"
      }
    ],
    "menus": {
      "comments/commentThread/context": [
        {
          "command": "redline-mark.createComment",
          "when": "commentController == redline-mark",
          "group": "inline"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [{
        "id": "redline-mark-sidebar",
        "title": "Redline Mark",
        "icon": "media/redlinemark.png"
      }]
    },
    "views": {
      "redline-mark-sidebar": [{
        "type": "webview",
        "id": "redline-mark.sidebar",
        "name": "Review Status"
      }]
    },
    "configuration": {
      "title": "Redline Mark",
      "properties": {
        "claudeReview.autoSave": {
          "type": "boolean",
          "default": true,
          "description": "Auto-save review comments"
        },
        "claudeReview.debounceMs": {
          "type": "number",
          "default": 1000,
          "description": "Debounce delay for file writes (ms)"
        },
        "claudeReview.enableFileWatcher": {
          "type": "boolean",
          "default": true,
          "description": "Watch for external changes to review files"
        },
        "redlineMark.excludePatterns": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Glob patterns to exclude from the file picker (e.g. \"**/CHANGELOG.md\", \"**/node_modules/**\")"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "npm run compile && node --test test/pathValidator.test.js test/schemaValidator.test.js test/anchorValidator.test.js"
  },
  "dependencies": {
    "nanoid": "^3.3.7"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/devenollc/redline-mark.git"
  },
  "license": "MIT"
}
